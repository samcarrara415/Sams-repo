{
  "name": "roblox-map-agent",
  "version": "0.2.0",
  "private": true,
  "description": "AI agent that builds complete Roblox maps using Claude Code (subscription) and Google Gemini via browser automation (subscription).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "roblox-map-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "mcp": "tsx src/mcp-server.ts",
    "typecheck": "tsc --noEmit",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.59.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}

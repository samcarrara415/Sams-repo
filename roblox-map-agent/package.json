{
  "name": "roblox-map-agent",
  "version": "0.1.0",
  "private": true,
  "description": "AI agent that builds complete Roblox maps using Claude (planner) and Google Gemini (image generation).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "roblox-map-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@google/genai": "^1.50.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}

# ---------------------------------------------------------------------------
# Claude Studio configuration
# ---------------------------------------------------------------------------

# Port the server listens on.
PORT=3000

# Secret used to sign session cookies. Set this to a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# "Log in with Claude" (OAuth) — the primary auth mode.
# These defaults use the public Claude Code OAuth client, which supports
# subscription-backed (Pro / Max) inference. You normally do NOT need to
# change them. Users log in with their own Claude account, so the AI usage
# is billed to *their* subscription, not to a shared API key.
# ---------------------------------------------------------------------------
CLAUDE_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
CLAUDE_OAUTH_AUTHORIZE_URL=https://claude.ai/oauth/authorize
CLAUDE_OAUTH_TOKEN_URL=https://console.anthropic.com/v1/oauth/token
CLAUDE_OAUTH_REDIRECT_URI=https://console.anthropic.com/oauth/code/callback
CLAUDE_OAUTH_SCOPES=org:create_api_key user:profile user:inference

# ---------------------------------------------------------------------------
# Optional API-key fallback. If a user has no Claude subscription they can
# instead paste an Anthropic API key at the login screen, or you can set a
# server-wide default here for local development.
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=

# Default model used for app generation. Users can switch in the UI.
DEFAULT_MODEL=claude-sonnet-5

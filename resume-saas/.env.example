# Supabase — from your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — your API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Stripe — from your Stripe Dashboard
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a $8/month recurring price in Stripe and paste its ID here:
STRIPE_MONTHLY_PRICE_ID=price_...

# Your deployed URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Your email — only this address can access /admin to generate promo codes
ADMIN_EMAIL=you@example.com
